# App
APP_NAME="LA Garage Doors API"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/garagedoors
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/garagedoors

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production-please-use-a-long-random-string-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# CORS - comma-separated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Business info
BUSINESS_NAME="LA Garage Doors Pro"
BUSINESS_PHONE="+13105551234"
BUSINESS_EMAIL="info@lagaragedoorspro.com"
BUSINESS_LICENSE="CSLB #1234567"
EMERGENCY_PHONE="+13105550911"
WHATSAPP_NUMBER="13105551234"

# Integrations (optional - leave empty for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
